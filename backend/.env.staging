# ==============================================================================
# NEXA AI — GLOBAL ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to .env.development, .env.testing, or .env.production as needed.
# For details, refer to: backend/app/core/config/README.md
# ==============================================================================

# ── SYSTEM CORE SETTINGS ──────────────────────────────────────────────────────
ENVIRONMENT=development # Options: development, testing, staging, production
DEBUG=true
SECRET_KEY=replace-with-a-secure-random-64-character-hex-string
API_V1_STR=/api/v1
PROJECT_NAME="NEXA AI Career guidance platform"

# ── DATABASES & VECTOR STACKS ─────────────────────────────────────────────────
# MongoDB Configuration
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASSWORD=secure-db-password
MONGO_DB=nexa_db
MONGO_URL=mongodb://admin:secure-db-password@localhost:27017/nexa_db?authSource=admin

# Redis Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# Qdrant Vector DB Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=optional-secure-vector-api-key
QDRANT_URL=http://localhost:6333

# ── CRYPTOGRAPHY & SESSIONS (JWT) ─────────────────────────────────────────────
# Access Token Lifetime: 15 minutes (900 seconds)
ACCESS_TOKEN_EXPIRE_SECONDS=900
# Refresh Token Lifetime: 7 days (604800 seconds)
REFRESH_TOKEN_EXPIRE_SECONDS=604800
# RS256 Key Pair (Paths to PEM key files or raw contents)
JWT_PRIVATE_KEY_PATH=/app/certs/private_key.pem
JWT_PUBLIC_KEY_PATH=/app/certs/public_key.pem

# ── THIRD-PARTY INTEGRATIONS ──────────────────────────────────────────────────
# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@nexa-ai.com
SMTP_PASSWORD=secure-gmail-app-password
SMTP_FROM_EMAIL=noreply@nexa-ai.com
SMTP_FROM_NAME="NEXA AI Mentor"

# OAuth Providers
GOOGLE_CLIENT_ID=google-client-id-here
GOOGLE_CLIENT_SECRET=google-client-secret-here
GITHUB_CLIENT_ID=github-client-id-here
GITHUB_CLIENT_SECRET=github-client-secret-here

# Storage Configuration (Local, S3)
STORAGE_PROVIDER=local # Options: local, s3
STORAGE_LOCAL_DIR=backend/uploads
S3_BUCKET_NAME=nexa-ai-uploads
AWS_ACCESS_KEY_ID=aws-key-id
AWS_SECRET_ACCESS_KEY=aws-secret-key

# ── AI ENGINE INTEGRATIONS ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-replace-with-openai-key
GEMINI_API_KEY=ai-replace-with-google-gemini-key
ANTHROPIC_API_KEY=sk-ant-replace-with-anthropic-key
COHERE_API_KEY=replace-with-cohere-key

# ── SYSTEM MONITORING ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
PROMETHEUS_METRICS_PORT=8000
LOKI_URL=http://localhost:3100/loki/api/v1/push

# ── CELERY TASK WORKERS ───────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
